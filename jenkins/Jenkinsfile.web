pipeline {
    agent any

    tools {
        nodejs 'NodeJS'
    }

    parameters {
        string(name: 'BRANCH',      defaultValue: 'main',            description: 'Branch to deploy')
        choice(name: 'ENVIRONMENT', choices: ['local', 'production'], description: 'Target environment')
    }

    environment {
        IMAGE_NAME       = 'ghcr.io/valanhyr/mana-forge-web'
        SERVICE          = 'web'
        // Production
        DEPLOY_HOST      = '91.98.206.23'
        DEPLOY_USER      = 'root'
        DEPLOY_PATH      = '/root/mana-forge'
        HEALTH_URL_PROD  = 'http://91.98.206.23'
        // Local
        HEALTH_URL_LOCAL = 'http://host.docker.internal:80'
    }

    stages {

        stage('Checkout') {
            steps {
                git branch: params.BRANCH,
                    url: 'https://github.com/valanhyr/mana-forge-app.git'
            }
        }

        stage('Validate') {
            when { expression { params.ENVIRONMENT == 'production' } }
            steps {
                script {
                    def version = sh(
                        returnStdout: true,
                        script: "grep '\"version\"' ./mana-forge-web/package.json | head -1 | sed 's/.*\"version\": *\"\\([^\"]*\\)\".*/\\1/'"
                    ).trim()
                    env.RELEASE_VERSION = version
                    echo "📦 Version: ${version}"
                    def tagExists = sh(
                        returnStatus: true,
                        script: "git fetch --tags && git tag -l 'web-v${version}' | grep -q ."
                    )
                    if (tagExists == 0) {
                        error("🚫 Version web-v${version} already released. Bump the version in package.json.")
                    }
                    echo "✅ Version web-v${version} is a new release — proceeding"
                }
            }
        }

        stage('Lint') {
            steps {
                sh '''
                    cd mana-forge-web
                    npm ci
                    npm run lint
                '''
            }
        }

        stage('Test') {
            steps {
                sh '''
                    cd mana-forge-web
                    npx vitest run --coverage --reporter=verbose --reporter=junit --outputFile=test-results/junit.xml
                '''
            }
            post {
                always {
                    script {
                        junit testResults: 'mana-forge-web/test-results/junit.xml',
                              allowEmptyResults: true,
                              skipPublishingChecks: true

                        catchError(buildResult: 'SUCCESS', stageResult: 'SUCCESS') {
                            recordCoverage(
                                tools: [[parser: 'COBERTURA', pattern: 'mana-forge-web/coverage/cobertura-coverage.xml']],
                                sourceDirectories: [[path: 'mana-forge-web/src']],
                                skipPublishingChecks: true
                            )
                        }
                    }
                }
            }
        }

        stage('Build') {
            steps {
                script {
                    env.IMAGE_TAG  = sh(returnStdout: true, script: 'git rev-parse --short HEAD').trim()
                    env.IMAGE_FULL = "${env.IMAGE_NAME}:${env.IMAGE_TAG}"
                }
                sh """
                    docker build \
                        --build-arg VITE_API_URL=/api \
                        -t ${env.IMAGE_FULL} \
                        -t ${env.IMAGE_NAME}:latest \
                        ./mana-forge-web
                """
            }
        }

        stage('Publish') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'ghcr-credentials',
                    usernameVariable: 'GHCR_USER',
                    passwordVariable: 'GHCR_TOKEN'
                )]) {
                    sh '''
                        echo "$GHCR_TOKEN" | docker login ghcr.io -u "$GHCR_USER" --password-stdin
                        docker push "$IMAGE_FULL"
                        docker push "$IMAGE_NAME:latest"
                    '''
                }
            }
        }

        stage('Deploy') {
            steps {
                script {
                    if (params.ENVIRONMENT == 'local') {
                        withCredentials([file(credentialsId: 'mana-forge-api', variable: 'ENV_FILE')]) {
                            sh '''
                                PREV=$(docker inspect mana-forge-web-1 --format='{{.Config.Image}}' 2>/dev/null || echo '')
                                echo "$PREV" > /tmp/previous_web_image
                                docker pull "$IMAGE_FULL"
                                cd $WORKSPACE
                                WEB_IMAGE="$IMAGE_FULL" docker-compose -p mana-forge --env-file "$ENV_FILE" up -d --no-build --no-deps --force-recreate web
                            '''
                        }
                    } else {
                        withCredentials([
                            usernamePassword(credentialsId: 'ghcr-credentials', usernameVariable: 'GHCR_USER', passwordVariable: 'GHCR_TOKEN'),
                            file(credentialsId: 'mana-forge-api', variable: 'ENV_FILE')
                        ]) {
                            sh '''
                                SSH="ssh -i /var/jenkins_home/.ssh/hetzner_key -o StrictHostKeyChecking=no $DEPLOY_USER@$DEPLOY_HOST"
                                SCP="scp -i /var/jenkins_home/.ssh/hetzner_key -o StrictHostKeyChecking=no"
                                PREV=$($SSH "docker inspect mana-forge-${SERVICE}-1 --format='{{.Config.Image}}' 2>/dev/null || echo ''")
                                $SSH "echo '$PREV' > /tmp/previous_${SERVICE}_image"
                                $SCP "$ENV_FILE" $DEPLOY_USER@$DEPLOY_HOST:/tmp/.env.deploy
                                $SSH "echo "$GHCR_TOKEN" | docker login ghcr.io -u "$GHCR_USER" --password-stdin && cd $DEPLOY_PATH && docker pull $IMAGE_FULL && WEB_IMAGE=$IMAGE_FULL docker compose --env-file /tmp/.env.deploy up -d --no-build --no-deps --force-recreate $SERVICE"
                                $SSH "rm -f /tmp/.env.deploy"
                            '''
                        }
                    }
                }
            }
        }

        stage('Healthcheck') {
            steps {
                script {
                    def healthUrl = params.ENVIRONMENT == 'local' ? env.HEALTH_URL_LOCAL : env.HEALTH_URL_PROD
                    def healthy = false
                    echo "⏳ Waiting for service to be healthy..."
                    for (int i = 1; i <= 12; i++) {
                        sleep(10)
                        def status = sh(
                            script: "curl -sf -o /dev/null -w '%{http_code}' ${healthUrl} || echo '000'",
                            returnStdout: true
                        ).trim()
                        echo "  Attempt ${i}/12: HTTP ${status}"
                        if (status ==~ /^[2-4][0-9]{2}$/) {
                            healthy = true
                            echo '✅ Service is healthy'
                            break
                        }
                    }
                    if (!healthy) {
                        error('❌ Healthcheck failed after 2 minutes — triggering rollback')
                    }
                }
            }
        }
    }

    post {
        failure {
            script {
                if (params.ENVIRONMENT == 'local') {
                    withCredentials([file(credentialsId: 'mana-forge-api', variable: 'ENV_FILE')]) {
                        sh '''
                            PREV=$(cat /tmp/previous_web_image 2>/dev/null || echo '')
                            if [ -n "$PREV" ]; then
                                echo "🔄 Rolling back to $PREV"
                                WEB_IMAGE="$PREV" docker-compose -p mana-forge --env-file "$ENV_FILE" -f $WORKSPACE/docker-compose.yml up -d --no-build --no-deps --force-recreate web
                            else
                                echo "⚠️  No previous image found"
                            fi
                        '''
                    }
                } else {
                    withCredentials([
                        file(credentialsId: 'mana-forge-api', variable: 'ENV_FILE')
                    ]) {
                        sh '''
                            SSH="ssh -i /var/jenkins_home/.ssh/hetzner_key -o StrictHostKeyChecking=no $DEPLOY_USER@$DEPLOY_HOST"
                            SCP="scp -i /var/jenkins_home/.ssh/hetzner_key -o StrictHostKeyChecking=no"
                            PREV=$($SSH "cat /tmp/previous_${SERVICE}_image 2>/dev/null || echo ''")
                            if [ -n "$PREV" ]; then
                                echo "🔄 Rolling back to $PREV"
                                $SCP "$ENV_FILE" $DEPLOY_USER@$DEPLOY_HOST:/tmp/.env.deploy
                                $SSH "cd $DEPLOY_PATH && WEB_IMAGE=$PREV docker compose --env-file /tmp/.env.deploy up -d --no-build --no-deps $SERVICE"
                                $SSH "rm -f /tmp/.env.deploy"
                            else
                                echo "⚠️  No previous image found — manual intervention required"
                            fi
                        '''
                    }
                }
            }
        }
        always {
            sh 'docker logout ghcr.io || true'
        }
        success {
            script {
                if (params.ENVIRONMENT == 'production' && env.RELEASE_VERSION) {
                    withCredentials([usernamePassword(
                        credentialsId: 'ghcr-credentials',
                        usernameVariable: 'GIT_USER',
                        passwordVariable: 'GIT_TOKEN'
                    )]) {
                        sh '''
                            git config user.email "jenkins@mana-forge"
                            git config user.name "Jenkins"
                            git tag "web-v${RELEASE_VERSION}"
                            git push "https://${GIT_USER}:${GIT_TOKEN}@github.com/valanhyr/mana-forge-app.git" "web-v${RELEASE_VERSION}"
                            echo "🏷️  Tagged web-v${RELEASE_VERSION}"
                        '''
                    }
                }
            }
        }
    }
}
