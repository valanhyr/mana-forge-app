pipeline {
    agent any

    parameters {
        string(name: 'BRANCH',      defaultValue: 'main',            description: 'Branch to deploy')
        choice(name: 'ENVIRONMENT', choices: ['local', 'production'], description: 'Target environment')
    }

    environment {
        IMAGE_NAME       = 'ghcr.io/valanhyr/mana-forge-web'
        SERVICE          = 'web'
        // Production
        DEPLOY_HOST      = '91.98.206.23'
        DEPLOY_USER      = 'root'
        DEPLOY_PATH      = '/root/mana-forge'
        HEALTH_URL_PROD  = 'http://91.98.206.23'
        // Local
        HEALTH_URL_LOCAL = 'http://host.docker.internal:80'
    }

    stages {

        stage('Checkout') {
            steps {
                git branch: params.BRANCH,
                    url: 'https://github.com/valanhyr/mana-forge-app.git'
            }
        }

        stage('Build') {
            steps {
                script {
                    env.IMAGE_TAG  = sh(returnStdout: true, script: 'git rev-parse --short HEAD').trim()
                    env.IMAGE_FULL = "${env.IMAGE_NAME}:${env.IMAGE_TAG}"
                }
                sh """
                    docker build \
                        --build-arg VITE_API_URL=/api \
                        -t ${env.IMAGE_FULL} \
                        -t ${env.IMAGE_NAME}:latest \
                        ./mana-forge-web
                """
            }
        }

        stage('Test') {
            steps {
                echo '⏭️  Tests not yet configured — skipping'
                // Future:
                // sh 'cd mana-forge-web && npm ci && npm test'
            }
        }

        stage('Publish') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'ghcr-credentials',
                    usernameVariable: 'GHCR_USER',
                    passwordVariable: 'GHCR_TOKEN'
                )]) {
                    sh '''
                        echo "$GHCR_TOKEN" | docker login ghcr.io -u "$GHCR_USER" --password-stdin
                        docker push "$IMAGE_FULL"
                        docker push "$IMAGE_NAME:latest"
                    '''
                }
            }
        }

        stage('Deploy') {
            steps {
                script {
                    if (params.ENVIRONMENT == 'local') {
                        withCredentials([file(credentialsId: 'mana-forge-api', variable: 'ENV_FILE')]) {
                            sh '''
                                PREV=$(docker inspect mana-forge-web-1 --format='{{.Config.Image}}' 2>/dev/null || echo '')
                                echo "$PREV" > /tmp/previous_web_image
                                docker pull "$IMAGE_FULL"
                                cd $WORKSPACE
                                WEB_IMAGE="$IMAGE_FULL" docker-compose -p mana-forge --env-file "$ENV_FILE" up -d --no-build --no-deps --force-recreate web
                            '''
                        }
                    } else {
                        withCredentials([
                            sshUserPrivateKey(credentialsId: 'hetzner-ssh-key', keyFileVariable: 'SSH_KEY'),
                            file(credentialsId: 'mana-forge-api', variable: 'ENV_FILE')
                        ]) {
                            sh '''
                                SSH="ssh -i $SSH_KEY -o StrictHostKeyChecking=no $DEPLOY_USER@$DEPLOY_HOST"
                                SCP="scp -i $SSH_KEY -o StrictHostKeyChecking=no"
                                PREV=$($SSH "docker inspect mana-forge-${SERVICE}-1 --format='{{.Config.Image}}' 2>/dev/null || echo ''")
                                $SSH "echo '$PREV' > /tmp/previous_${SERVICE}_image"
                                $SCP "$ENV_FILE" $DEPLOY_USER@$DEPLOY_HOST:/tmp/.env.deploy
                                $SSH "cd $DEPLOY_PATH && docker pull $IMAGE_FULL && WEB_IMAGE=$IMAGE_FULL docker compose --env-file /tmp/.env.deploy up -d --no-build --no-deps $SERVICE"
                                $SSH "rm -f /tmp/.env.deploy"
                            '''
                        }
                    }
                }
            }
        }

        stage('Healthcheck') {
            steps {
                script {
                    def healthUrl = params.ENVIRONMENT == 'local' ? env.HEALTH_URL_LOCAL : env.HEALTH_URL_PROD
                    def healthy = false
                    echo "⏳ Waiting for service to be healthy..."
                    for (int i = 1; i <= 12; i++) {
                        sleep(10)
                        def status = sh(
                            script: "curl -sf -o /dev/null -w '%{http_code}' ${healthUrl} || echo '000'",
                            returnStdout: true
                        ).trim()
                        echo "  Attempt ${i}/12: HTTP ${status}"
                        if (status ==~ /^[2-4][0-9]{2}$/) {
                            healthy = true
                            echo '✅ Service is healthy'
                            break
                        }
                    }
                    if (!healthy) {
                        error('❌ Healthcheck failed after 2 minutes — triggering rollback')
                    }
                }
            }
        }
    }

    post {
        failure {
            script {
                if (params.ENVIRONMENT == 'local') {
                    withCredentials([file(credentialsId: 'mana-forge-api', variable: 'ENV_FILE')]) {
                        sh '''
                            PREV=$(cat /tmp/previous_web_image 2>/dev/null || echo '')
                            if [ -n "$PREV" ]; then
                                echo "🔄 Rolling back to $PREV"
                                WEB_IMAGE="$PREV" docker-compose -p mana-forge --env-file "$ENV_FILE" -f $WORKSPACE/docker-compose.yml up -d --no-build --no-deps --force-recreate web
                            else
                                echo "⚠️  No previous image found"
                            fi
                        '''
                    }
                } else {
                    withCredentials([
                        sshUserPrivateKey(credentialsId: 'hetzner-ssh-key', keyFileVariable: 'SSH_KEY'),
                        file(credentialsId: 'mana-forge-api', variable: 'ENV_FILE')
                    ]) {
                        sh '''
                            SSH="ssh -i $SSH_KEY -o StrictHostKeyChecking=no $DEPLOY_USER@$DEPLOY_HOST"
                            SCP="scp -i $SSH_KEY -o StrictHostKeyChecking=no"
                            PREV=$($SSH "cat /tmp/previous_${SERVICE}_image 2>/dev/null || echo ''")
                            if [ -n "$PREV" ]; then
                                echo "🔄 Rolling back to $PREV"
                                $SCP "$ENV_FILE" $DEPLOY_USER@$DEPLOY_HOST:/tmp/.env.deploy
                                $SSH "cd $DEPLOY_PATH && WEB_IMAGE=$PREV docker compose --env-file /tmp/.env.deploy up -d --no-build --no-deps $SERVICE"
                                $SSH "rm -f /tmp/.env.deploy"
                            else
                                echo "⚠️  No previous image found — manual intervention required"
                            fi
                        '''
                    }
                }
            }
        }
        always {
            sh 'docker logout ghcr.io || true'
        }
    }
}

